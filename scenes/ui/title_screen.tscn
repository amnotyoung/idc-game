[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/title_screen.gd" id="1"]
[ext_resource type="Texture2D" path="res://assets/sprites/tilesets/title_bg.png" id="title_bg"]

[node name="TitleScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

; 배경 (타이틀 이미지)
[node name="BG" type="TextureRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
texture = ExtResource("title_bg")
expand_mode = 1
stretch_mode = 5

; 부제 (타이틀은 배경 이미지에 포함)
[node name="Subtitle" type="Label" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -100.0
offset_top = 36.0
offset_right = 100.0
offset_bottom = 46.0
text = "나이탬바 섬 이야기"
theme_override_font_sizes/font_size = 7
horizontal_alignment = 1
modulate = Color(0.95, 0.92, 0.85, 0.9)

; 버튼 컨테이너
[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -40.0
offset_top = 100.0
offset_right = 40.0
offset_bottom = 178.0
theme_override_constants/separation = 6

[node name="NewGameBtn" type="Button" parent="VBox"]
text = "새 게임"
theme_override_font_sizes/font_size = 10

[node name="ContinueBtn" type="Button" parent="VBox"]
text = "이어하기"
theme_override_font_sizes/font_size = 10

[connection signal="pressed" from="VBox/NewGameBtn" to="." method="_on_new_game_pressed"]
