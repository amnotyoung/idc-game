  "ch3_mere_first": {
    "lines": [
      {"speaker": "Mere", "text": "아, 왔네요. 저도 어제 도착했어요."},
      {"speaker": "Mere", "text": "여기 오래된 사업이라서 배경 좀 파봐야 할 것 같아서요."},
      {"speaker": "Mere", "text": "Ratu Josefa는 만났어요? 어른한테 인사부터 해야 해요. 양고나 챙겼죠?"},
      {"speaker": "Mere", "text": "그리고 — 10년 전 사업 때 시공사가 마을 상의 없이 위치 정했대요."},
      {"speaker": "Mere", "text": "물탱크가 밭 한가운데 세워져서 농사를 못 짓게 된 집도 있었고요."},
      {"speaker": "Mere", "text": "그 얘기 나오면 '우리가 결정권 있다'는 걸 보여주는 게 중요해요."}
    ],
    "choices": [
      {
        "text": "\"좋은 정보예요. Mere 씨 현장 조사 결과 나중에 공유해줄 수 있어요?\"",
        "effects": { "mere": 15 },
        "next": "ch3_mere_first_end"
      },
      {
        "text": "\"알겠어요.\"",
        "effects": { "mere": 5 },
        "next": "ch3_mere_first_end"
      }
    ]
  },

  "ch3_mere_first_end": {
    "lines": [
      {"speaker": "Mere", "text": "그럼 Ratu Josefa한테 먼저 가봐요. 전 여기서 조사 계속할게요."}
    ]
  },

  "ch3_mere_after_ratu": {
    "lines": [
      {"speaker": "Mere", "text": "여기 사람들 말 잘 들어봐요. 서류엔 없는 얘기들이에요."},
      {"speaker": "Mere", "text": "10년 전에 뭐가 잘못됐는지 직접 듣는 게 제일 빨라요."},
      {"speaker": "Mere", "text": "아까 Lani라는 청년 봤어요? 마을 청년회 리더예요."},
      {"speaker": "Mere", "text": "주민들 사이에서 영향력 있어요. 그 사람 설득하는 게 핵심이에요."}
    ]
  },

  "ch3_mere_after_good": {
    "lines": [
      {"speaker": "Mere", "text": "잘 됐네요. Ratu Josefa가 문 열어주는 사람 얼마 없어요."},
      {"speaker": "Mere", "text": "제 조사 결과 공유할게요 — 마을 청년 중에 배관 기술자가 있어요. Josua라는 사람이요."},
      {"speaker": "Mere", "text": "이 사람을 운영위원회에 넣으면 유지보수 문제가 풀려요."}
    ],
    "choices": [
      {
        "text": "\"Mere 씨 덕분에 그림이 그려져요. 정말 감사해요.\"",
        "effects": { "mere": 15 },
        "next": "ch3_mere_after_good_end"
      },
      {
        "text": "\"알겠어요. 참고할게요.\"",
        "effects": { "mere": 5 },
        "next": "ch3_mere_after_good_end"
      }
    ]
  },

  "ch3_mere_after_good_end": {
    "lines": [
      {"speaker": "Mere", "text": "토지청 가서 Sela 만나보세요. 저는 여기서 좀 더 조사할게요."}
    ]
  },

  "ch3_mere_after_neutral": {
    "lines": [
      {"speaker": "Mere", "text": "시간이 좀 걸릴 것 같네요."},
      {"speaker": "Mere", "text": "주민들이랑 신뢰 쌓는 데 서두르지 마요."}
    ]
  },

  "ch3_consent_ratu": {
    "lines": [
      {"speaker": "나", "text": "Ratu Josefa, 토지청에서 마을 동의서가 필요하다고 합니다."},
      {"speaker": "나", "text": "Ratu의 서명이 있으면 사업 승인 절차가 진행됩니다."},
      {"speaker": "Ratu Josefa", "text": "...동의서."},
      {"speaker": "Ratu Josefa", "text": "10년 전에도 비슷한 서류에 서명한 적 있소."},
      {"speaker": "Ratu Josefa", "text": "그때 서명한 뒤에 뭐가 바뀌었소? 아무것도."}
    ],
    "choices": [
      {
        "text": "\"이번엔 마을이 직접 관리합니다. Lani와 Josua가 운영위원회에 참여해요.\"",
        "effects": {"ratu_josefa": 10, "lani": 15},
        "next": "ch3_consent_sign"
      },
      {
        "text": "\"Ratu의 판단을 존중합니다. 필요하시면 시간을 드릴게요.\"",
        "effects": {"ratu_josefa": 5, "lani": 5},
        "next": "ch3_consent_sign"
      }
    ]
  },

  "ch3_consent_sign": {
    "lines": [
      {"speaker": "Ratu Josefa", "text": "...좋소."},
      {"speaker": "", "text": "Ratu Josefa가 서류를 천천히 읽었다."},
      {"speaker": "Ratu Josefa", "text": "마을 운영위원회 조항이 있군. 이건 처음이오."},
      {"speaker": "Lani", "text": "Ratu, 저도 운영위원회에 들어간대요. Josua 삼촌도요."},
      {"speaker": "Ratu Josefa", "text": "...그래?"},
      {"speaker": "", "text": "Ratu가 Lani를 보며 잠깐 웃었다."},
      {"speaker": "", "text": "Ratu가 펜을 들어 서명했다."},
      {"speaker": "Ratu Josefa", "text": "이 서명은 마을 사람들한테 한 약속이오. 당신한테 한 게 아니야."},
      {"speaker": "Ratu Josefa", "text": "잊지 마시오."}
    ]
  },

  "ch3_consent_ratu_neutral": {
    "lines": [
      {"speaker": "나", "text": "Ratu Josefa, 토지청에서 동의서를 요청했습니다."},
      {"speaker": "Ratu Josefa", "text": "...당신이 뭘 약속할 수 있는지 아직 모르겠소."},
      {"speaker": "Ratu Josefa", "text": "서명은 아직 못 하겠소."},
      {"speaker": "", "text": "동의서를 받지 못했다."}
    ]
  },

  "ch3_consent_done": {
    "lines": [
      {"speaker": "Ratu Josefa", "text": "서명은 했소. 약속 지키시오."}
    ]
  },

  "ch3_mere_consent": {
    "lines": [
      {"speaker": "Mere", "text": "서명 받았어요?"},
      {"speaker": "Mere", "text": "이거 큰 거예요. Ratu Josefa가 서명하는 건 쉬운 일이 아니에요."},
      {"speaker": "Mere", "text": "이제 수바로 돌아가서 마무리하면 돼요."}
    ]
  }
}
