  "ch3_sevusevu_good": {
    "lines": [
      {"speaker": "Ratu Josefa", "text": "...알고 왔군요."},
      {"speaker": "Ratu Josefa", "text": "들어오시오. 함께 앉읍시다."},
      {"speaker": "", "text": "세부세부가 시작됐다. 양고나 그릇이 천천히 돌아갔다."},
      {"speaker": "Ratu Josefa", "text": "기억하는 것들이 있소. 10년 전 약속. 아무것도 남지 않았지."},
      {"speaker": "Ratu Josefa", "text": "당신은 몇 번째요?"}
    ],
    "choices": [
      {
        "text": "\"세 번째입니다. 사과드립니다.\"",
        "effects": {"ratu_josefa": 15},
        "next": "ch3_village_talk"
      },
      {
        "text": "\"이번엔 다를 겁니다.\"",
        "effects": {"ratu_josefa": 5},
        "next": "ch3_village_talk"
      }
    ]
  },

  "ch3_sevusevu_miss": {
    "lines": [
      {"speaker": "Ratu Josefa", "text": "...그렇군요."},
      {"speaker": "", "text": "짧은 침묵이 흘렀다."},
      {"speaker": "Ratu Josefa", "text": "앉으시오. 얘기는 들어봐야지."}
    ],
    "choices": [
      {
        "text": "\"고맙습니다. 잘 부탁드리겠습니다.\"",
        "effects": {"ratu_josefa": 5},
