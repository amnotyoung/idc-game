{
  "ch1_arrival": {
    "lines": [
      {
        "speaker": "",
        "text": "수바, 피지. 2024년 3월."
      },
      {
        "speaker": "",
        "text": "KODA 피지 사무소. 전임자는 3일 전에 귀국했다."
      },
      {
        "speaker": "",
        "text": "책상 위에 메모 한 장이 남아있다."
      },
      {
        "speaker": "메모",
        "text": "\"나이탬바 섬 사업 — 잘 부탁해. 미안.\""
      },
      {
        "speaker": "",
        "text": "사업 파일을 열었다. 마지막 업데이트: 6개월 전."
      }
    ]
  },

  "ch1_mere_entrance": {
    "lines": [
      {
        "speaker": "???",
        "text": "실례합니다."
      },
      {
        "speaker": "???",
        "text": "KODA 담당자 찾아왔는데요."
      },
      {
        "speaker": "Mere",
        "text": "...또 새 사람이에요?"
      },
      {
        "speaker": "Mere",
        "text": "몇 번째야, 진짜."
      }
    ],
    "choices": [
      {
        "text": "\"죄송합니다. 저도 방금 왔어요.\"",
        "effects": { "mere": 10 },
        "next": "ch1_mere_honest"
      },
      {
        "text": "\"안녕하세요. 어떻게 오셨나요?\"",
        "effects": { "mere": -5 },
        "next": "ch1_mere_formal"
      }
    ]
  },

  "ch1_mere_honest": {
    "lines": [
      {
        "speaker": "Mere",
        "text": "...솔직하네요."
      },
      {
        "speaker": "Mere",
        "text": "나이탬바 섬 사업 때문에 왔어요. 6개월째 아무 진전이 없어요."
      },
      {
        "speaker": "Mere",
        "text": "섬 주민들은 기다리다 지쳤고요."
      },
      {
        "speaker": "Mere",
        "text": "제 이름은 Mere예요. Pacific Roots NGO에서 일해요."
      },
      {
        "speaker": "Mere",
        "text": "...일단 뭐가 막혀있는지는 알아요?"
      }
    ],
    "choices": [
      {
        "text": "\"아직 파악 중이에요. 같이 봐줄 수 있어요?\"",
        "effects": { "mere": 15 },
        "next": "ch1_situation_briefing"
      },
      {
        "text": "\"제가 먼저 파일 검토하고 연락드릴게요.\"",
        "effects": { "mere": -5 },
        "next": "ch1_situation_briefing"
      }
    ]
  },

  "ch1_mere_formal": {
    "lines": [
      {
        "speaker": "Mere",
        "text": "Pacific Roots NGO에서 왔어요. Mere Vuniwai입니다."
      },
      {
        "speaker": "Mere",
        "text": "나이탬바 섬 사업 담당자 맞죠?"
      },
      {
        "speaker": "Mere",
        "text": "6개월째 진전이 없어요. 언제까지 기다려야 하나요?"
      }
    ],
    "choices": [
      {
        "text": "\"상황 파악하는 중이에요. 같이 볼 수 있을까요?\"",
        "effects": { "mere": 10 },
        "next": "ch1_situation_briefing"
      },
      {
        "text": "\"내부 검토 후 공식 연락드리겠습니다.\"",
        "effects": { "mere": -10 },
        "next": "ch1_situation_briefing"
      }
    ]
  },

  "ch1_situation_briefing": {
    "lines": [
      {
        "speaker": "Mere",
        "text": "문제가 두 가지예요."
      },
      {
        "speaker": "Mere",
        "text": "첫째, 정부 승인이 3개월째 국가계획부에 묶여있어요."
      },
      {
        "speaker": "Mere",
        "text": "둘째, 섬 주민들이 이 사업 자체를 믿지 않아요."
      },
      {
        "speaker": "Mere",
        "text": "10년 전에도 비슷한 약속이 있었거든요. 아무것도 안 남았어요."
      },
      {
        "speaker": "",
        "text": "두 문제를 동시에 풀어야 한다."
      },
      {
        "speaker": "",
        "text": "혼자서는 어려울 것 같다."
      }
    ]
  }
}
