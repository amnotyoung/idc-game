{
  "ch2_enter_building": {
    "lines": [
      {"speaker": "", "text": "— 며칠 후 —"},
      {"speaker": "", "text": "피지 정부청사. 국가계획부 3층."},
      {"speaker": "", "text": "약속 시간 5분 전."}
    ]
  },
  "ch2_receptionist": {
    "lines": [
      {"speaker": "접수처", "text": "Timoci 씨 면담 예약하셨어요? 성함이?"},
      {"speaker": "접수처", "text": "잠깐만요, 확인해볼게요."},
      {"speaker": "접수처", "text": "...네, 있네요. 앉아서 기다려주세요."}
    ]
  },
  "ch2_waiting_note": {
    "lines": [
      {"speaker": "", "text": "대기실 테이블 위에 서류가 놓여있다."},
      {"speaker": "서류", "text": "\"2024 국가 인프라 예산 검토 — 검토 보류 항목 목록\""},
      {"speaker": "", "text": "나이탬바 섬 수자원 사업이 목록에 있다."}
    ]
  },
  "ch2_timoci_noshow_1": {
    "lines": [
      {"speaker": "접수처", "text": "죄송한데요... Timoci 씨가 긴급 회의가 생겼다고."},
      {"speaker": "접수처", "text": "다음 주 같은 시간으로 다시 잡아드릴까요?"}
    ],
    "choices": [
      {
        "text": "\"알겠습니다. 다시 잡아주세요.\"",
        "effects": {"timoci": 0},
        "next": "ch2_reschedule_ok"
      },
      {
        "text": "\"오늘 꼭 만나야 해요. 잠깐이라도 안 될까요?\"",
        "effects": {"timoci": -10},
        "next": "ch2_reschedule_push"
      }
    ]
  },
  "ch2_reschedule_ok": {
    "lines": [
      {"speaker": "", "text": "다음 주 화요일 오후 2시."},
      {"speaker": "", "text": "사무실로 돌아갔다."}
    ]
  },
  "ch2_reschedule_push": {
    "lines": [
      {"speaker": "접수처", "text": "...제가 한번 여쭤볼게요."},
      {"speaker": "접수처", "text": "죄송해요. Timoci 씨가 지금은 정말 어렵다고 하세요."},
      {"speaker": "", "text": "어쩔 수 없다."}
    ]
  },
  "ch2_second_visit_arrive": {
    "lines": [
      {"speaker": "", "text": "일주일 후. 같은 장소."},
      {"speaker": "접수처", "text": "오셨어요? Timoci 씨 지금 자리에 계세요. 올라가세요."}
    ]
  },
  "ch2_timoci_first": {
    "lines": [
      {"speaker": "Timoci", "text": "앉으세요."},
      {"speaker": "Timoci", "text": "KODA에서 오셨죠. 나이탬바 섬 건."},
      {"speaker": "Timoci", "text": "15분밖에 없어요. 바로 말씀해주세요."}
    ],
    "choices": [
      {
        "text": "\"승인이 왜 이렇게 오래 걸리는지 알고 싶어요.\"",
        "effects": {"timoci": 5},
        "next": "ch2_timoci_ask_reason"
      },
      {
        "text": "\"빨리 승인해주셔야 합니다. 6개월이 지났어요.\"",
        "effects": {"timoci": -15},
        "next": "ch2_timoci_pressure"
      },
      {
        "text": "\"사업 개요서 가져왔어요. 같이 보시겠어요?\"",
        "effects": {"timoci": 8},
        "next": "ch2_timoci_document"
      }
    ]
  },
  "ch2_timoci_ask_reason": {
    "lines": [
      {"speaker": "Timoci", "text": "...예산 항목 검토가 필요해요."},
      {"speaker": "Timoci", "text": "수자원부랑 지방부 관할이 겹쳐요. 정리가 안 됐어요."},
      {"speaker": "Timoci", "text": "우리 부서만 결정할 수 있는 게 아니에요."},
      {"speaker": "", "text": "핑계처럼 들리지만 — 실제 문제일 수도 있다."}
    ],
    "choices": [
      {
        "text": "\"어느 부서랑 조율이 필요한지 알 수 있을까요?\"",
        "effects": {"timoci": 10},
        "next": "ch2_timoci_collaborate"
      },
      {
        "text": "\"그건 내부 문제 아닌가요? 저희는 언제까지 기다려야 해요?\"",
        "effects": {"timoci": -8},
        "next": "ch2_timoci_frustrated"
      }
    ]
  },
  "ch2_timoci_pressure": {
    "lines": [
      {"speaker": "Timoci", "text": "...6개월이요."},
      {"speaker": "Timoci", "text": "저희도 바쁩니다. 서류가 없어서 못 하는 게 아니에요."},
      {"speaker": "Timoci", "text": "오늘 시간 다 됐어요. 다음에 오세요."},
      {"speaker": "", "text": "Timoci가 자리에서 일어났다."}
    ]
  },
  "ch2_timoci_document": {
    "lines": [
      {"speaker": "Timoci", "text": "...봅시다."},
      {"speaker": "Timoci", "text": "예산 항목이 여기 — 수자원부 코드로 되어있네요."},
      {"speaker": "Timoci", "text": "우리 부서 코드로 바꿔야 해요. 이게 안 되어있으면 결재가 안 올라가요."},
      {"speaker": "", "text": "구체적인 문제가 나왔다."}
    ],
    "choices": [
      {
        "text": "\"수정하면 바로 진행될까요?\"",
        "effects": {"timoci": 12},
        "next": "ch2_timoci_progress"
      }
    ]
  },
  "ch2_timoci_collaborate": {
    "lines": [
      {"speaker": "Timoci", "text": "지방부 조율은 제가 해볼게요."},
      {"speaker": "Timoci", "text": "서류 예산 코드만 수정해 오세요. 그게 먼저예요."},
      {"speaker": "", "text": "Timoci가 직접 움직이겠다고 했다."}
    ]
  },
  "ch2_timoci_frustrated": {
    "lines": [
      {"speaker": "Timoci", "text": "저도 규정대로 하는 거예요."},
      {"speaker": "Timoci", "text": "오늘은 여기까지 하죠."},
      {"speaker": "", "text": "미팅이 끝났다."}
    ]
  },
  "ch2_timoci_progress": {
    "lines": [
      {"speaker": "Timoci", "text": "수정된 서류 가져오면 일주일 안에 처리할게요."},
      {"speaker": "Timoci", "text": "Wati 씨가 절차 알 거예요. 같이 오면 빠를 거예요."},
      {"speaker": "", "text": "처음으로 구체적인 진전이 생겼다."}
    ]
  },

  "ch2_receptionist_2nd": {
    "lines": [
      {"speaker": "접수처", "text": "오셨어요? Timoci 씨 자리에 계세요."}
    ]
  },

  "ch2_timoci_after_good": {
    "lines": [
      {"speaker": "Timoci", "text": "서류 수정하면 연락주세요. 기다리고 있을게요."}
    ]
  },

  "ch2_timoci_after_frustrated": {
    "lines": [
      {"speaker": "Timoci", "text": "...오늘은 더 드릴 말씀이 없어요."}
    ]
  },

  "ch2_timoci_after_pressure": {
    "lines": [
      {"speaker": "Timoci", "text": "할 말은 다 했어요. 다음엔 약속 잡고 오세요."}
    ]
  },

  "ch3_wati_island_prep": {
    "lines": [
      {"speaker": "Wati", "text": "서류 수정은 제가 도와드릴게요."},
      {"speaker": "Wati", "text": "근데... 섬에도 가보셔야 해요."},
      {"speaker": "Wati", "text": "정부 승인만 받아도, 주민들이 안 받아들이면 소용없어요."},
      {"speaker": "Wati", "text": "가시기 전에 — 세부세부 아세요? 카바 가져가야 해요."},
      {"speaker": "Wati", "text": "빈손으로 마을 방문하면 실례예요. 수바 시장에서 구할 수 있어요."}
    ]
  },

  "ch3_wati_island_idle": {
    "lines": [
      {"speaker": "Wati", "text": "섬에 다녀오셨어요?"}
    ]
  }
}
