{
  "ch2_no_appointment": {
    "lines": [
      {"speaker": "접수처", "text": "안녕하세요. 어떻게 오셨어요?"},
      {"speaker": "접수처", "text": "Timoci 씨요? 예약 없이는 면담이 어렵습니다."},
      {"speaker": "접수처", "text": "담당자를 통해 사전 예약을 해주세요."}
    ]
  },

  "ch2_enter_building": {
    "lines": [
      {"speaker": "", "text": "— 며칠 후 —"},
      {"speaker": "", "text": "피지 정부청사. 국가계획부 3층."},
      {"speaker": "", "text": "약속 시간 5분 전."}
    ]
  },
  "ch2_receptionist": {
    "lines": [
      {"speaker": "접수처", "text": "Timoci 씨 면담 예약하셨어요? 성함이?"},
      {"speaker": "접수처", "text": "잠깐만요, 확인해볼게요."},
      {"speaker": "접수처", "text": "...네, 있네요. 앉아서 기다려주세요."}
    ]
  },
  "ch2_waiting_note": {
    "lines": [
      {"speaker": "", "text": "대기실 테이블 위에 서류가 놓여있다."},
      {"speaker": "서류", "text": "\"2024 국가 인프라 예산 검토 — 검토 보류 항목 목록\""},
      {"speaker": "", "text": "나이탬바 섬 수자원 사업이 목록에 있다."}
    ]
  },
  "ch2_timoci_noshow_1": {
    "lines": [
      {"speaker": "접수처", "text": "죄송한데요... Timoci 씨가 긴급 회의가 생겼다고."},
      {"speaker": "접수처", "text": "다음 주 같은 시간으로 다시 잡아드릴까요?"}
    ],
    "choices": [
      {
        "text": "\"알겠습니다. 다시 잡아주세요.\"",
        "effects": {"timoci": 0},
        "next": "ch2_reschedule_ok"
      },
      {
        "text": "\"오늘 꼭 만나야 해요. 잠깐이라도 안 될까요?\"",
        "effects": {"timoci": -10},
        "next": "ch2_reschedule_push"
      }
    ]
  },
  "ch2_reschedule_ok": {
    "lines": [
      {"speaker": "", "text": "다음 주 화요일 오후 2시."},
      {"speaker": "", "text": "사무실로 돌아갔다."}
    ]
  },
  "ch2_reschedule_push": {
    "lines": [
      {"speaker": "접수처", "text": "...제가 한번 여쭤볼게요."},
      {"speaker": "접수처", "text": "죄송해요. Timoci 씨가 지금은 정말 어렵다고 하세요."},
      {"speaker": "", "text": "어쩔 수 없다."}
    ]
  },
  "ch2_second_visit_arrive": {
    "lines": [
      {"speaker": "", "text": "일주일 후. 같은 장소."},
      {"speaker": "접수처", "text": "오셨어요? Timoci 씨 지금 자리에 계세요. 올라가세요."}
    ]
  },
  "ch2_timoci_first": {
    "lines": [
      {"speaker": "Timoci", "text": "앉으세요."},
      {"speaker": "Timoci", "text": "KODA에서 오셨죠. 나이탬바 섬 건."},
      {"speaker": "Timoci", "text": "15분밖에 없어요. 바로 말씀해주세요."}
    ],
    "choices": [
      {
        "text": "\"승인이 왜 이렇게 오래 걸리는지 알고 싶어요.\"",
        "effects": {"timoci": 5},
        "next": "ch2_timoci_ask_reason"
      },
      {
        "text": "\"빨리 승인해주셔야 합니다. 6개월이 지났어요.\"",
        "effects": {"timoci": -15},
        "next": "ch2_timoci_pressure"
      },
      {
        "text": "\"사업 개요서 가져왔어요. 같이 보시겠어요?\"",
        "effects": {"timoci": 8},
        "next": "ch2_timoci_document"
      }
    ]
  },
  "ch2_timoci_ask_reason": {
    "lines": [
      {"speaker": "Timoci", "text": "...장관 결재가 아직 안 났어요."},
      {"speaker": "Timoci", "text": "나이탬바 섬 토지가 iTaukei 공유지라서요. TLTB 동의 절차가 선행되어야 한다는 의견이 있어요."},
      {"speaker": "Timoci", "text": "저희 부서에서 올렸는데 위에서 그 부분을 지적하고 있어요."},
      {"speaker": "", "text": "핑계처럼 들리지만 — 실제 절차 문제일 수 있다."}
    ],
    "choices": [
      {
        "text": "\"어느 부서랑 조율이 필요한지 알 수 있을까요?\"",
        "effects": {"timoci": 10},
        "next": "ch2_timoci_collaborate"
      },
      {
        "text": "\"그건 내부 문제 아닌가요? 저희는 언제까지 기다려야 해요?\"",
        "effects": {"timoci": -8},
        "next": "ch2_timoci_frustrated"
      }
    ]
  },
  "ch2_timoci_pressure": {
    "lines": [
      {"speaker": "Timoci", "text": "저희도 최대한 빠르게 처리하려고 해요."},
      {"speaker": "Timoci", "text": "다만 내부 검토 절차가 있고, 저 혼자 결정할 수 있는 게 아니에요."},
      {"speaker": "Timoci", "text": "오늘은 여기까지 하죠."},
      {"speaker": "", "text": "Timoci가 자리에서 일어났다."}
    ]
  },
  "ch2_timoci_document": {
    "lines": [
      {"speaker": "Timoci", "text": "...봅시다."},
      {"speaker": "Timoci", "text": "나이탬바 섬. 토지 현황이 여기 빠져있네요."},
      {"speaker": "Timoci", "text": "섬 토지가 iTaukei 공유지예요. 장관 결재 전에 TLTB 검토가 있어야 한다는 게 위쪽 의견이에요."},
      {"speaker": "Timoci", "text": "저희가 올릴 수는 있는데, 그 부분 없이는 반려될 가능성이 높아요."},
      {"speaker": "", "text": "구체적인 병목이 확인됐다."}
    ],
    "choices": [
      {
        "text": "\"TLTB 쪽이랑 협의가 진행 중인지 확인해보겠습니다.\"",
        "effects": {"timoci": 12},
        "next": "ch2_timoci_progress"
      }
    ]
  },
  "ch2_timoci_collaborate": {
    "lines": [
      {"speaker": "Timoci", "text": "TLTB 쪽 협의가 되면 저희도 움직일 수 있어요."},
      {"speaker": "Timoci", "text": "그게 정리되면 장관 결재도 빨리 날 거예요."},
      {"speaker": "", "text": "Timoci가 솔직하게 말해줬다."}
    ]
  },
  "ch2_timoci_frustrated": {
    "lines": [
      {"speaker": "Timoci", "text": "저희도 규정 안에서 할 수 있는 걸 하고 있어요."},
      {"speaker": "Timoci", "text": "오늘은 여기까지 하죠."},
      {"speaker": "", "text": "미팅이 끝났다."}
    ]
  },
  "ch2_timoci_progress": {
    "lines": [
      {"speaker": "Timoci", "text": "TLTB 쪽이랑 협의 되면 저희가 다시 검토해볼게요."},
      {"speaker": "Timoci", "text": "Wati 씨가 그쪽 창구를 알 거예요."},
      {"speaker": "", "text": "처음으로 구체적인 진전이 생겼다."}
    ]
  },

  "ch2_receptionist_2nd": {
    "lines": [
      {"speaker": "접수처", "text": "오셨어요? Timoci 씨 자리에 계세요."}
    ]
  },

  "ch2_receptionist_after": {
    "lines": [
      {"speaker": "접수처", "text": "다 끝나셨어요? 수고하셨습니다."}
    ]
  },

  "ch2_timoci_after_good": {
    "lines": [
      {"speaker": "Timoci", "text": "서류 수정하면 연락주세요. 기다리고 있을게요."}
    ]
  },

  "ch2_timoci_after_frustrated": {
    "lines": [
      {"speaker": "Timoci", "text": "...오늘은 더 드릴 말씀이 없어요."}
    ]
  },

  "ch2_timoci_after_pressure": {
    "lines": [
      {"speaker": "Timoci", "text": "할 말은 다 했어요. 다음엔 약속 잡고 오세요."}
    ]
  },

  "ch3_wati_island_prep": {
    "lines": [
      {"speaker": "Wati", "text": "서류 수정은 제가 도와드릴게요."},
      {"speaker": "Wati", "text": "근데... 섬에도 가보셔야 해요."},
      {"speaker": "Wati", "text": "정부 승인만 받아도, 주민들이 안 받아들이면 소용없어요."},
      {"speaker": "Wati", "text": "가시기 전에 — 세부세부 아세요? 마을 어른 처음 만날 때 양고나 드리는 의식이에요."},
      {"speaker": "Wati", "text": "양고나 없이 가면 실례예요. 챙겨서 가세요."},
      {"speaker": "나", "text": "알겠어요. 챙겨갈게요."}
    ]
  },

  "ch1_wati_island_first": {
    "lines": [
      {"speaker": "Wati", "text": "섬에 먼저 가셨어요?"},
      {"speaker": "Wati", "text": "정부 승인도 아직인데... 어떻게 됐어요?"},
      {"speaker": "Wati", "text": "...일단 Timoci 씨 만나는 게 급해요. 정부청사 먼저 가보세요."}
    ]
  },

  "ch3_wati_island_idle": {
    "lines": [
      {"speaker": "Wati", "text": "섬에 다녀오셨어요?"}
    ]
  }
}
