; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Aid World"
config/description="A game about international development cooperation set in Fiji."
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/sprites/ui/icon.svg"

[autoload]

DialogueManager="*res://scripts/systems/dialogue_manager.gd"
TrustManager="*res://scripts/systems/trust_manager.gd"
SceneManager="*res://scenes/systems/scene_manager.tscn"
MobileInput="*res://scripts/systems/mobile_input.gd"
MobileControls="*res://scenes/ui/mobile_controls.tscn"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="res://assets/fonts/NanumGothic-Regular.ttf"

[rendering]

textures/canvas_textures/default_texture_filter=0
